# ── Environment / Secrets ─────────────────────────────────────────────
# All .env variants are ignored — NEVER commit real keys
.env
.env.local
.env.*.local
.env.development
.env.production
# .env.example is SAFE to commit — it has only placeholder values

# ── Node / npm ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Vite build output ─────────────────────────────────────────────────
dist/
dist-ssr/
.vite/
*.timestamp-*.mjs

# ── Python virtual environments ───────────────────────────────────────
venv/
.venv/
__pycache__/
*.py[cod]
*.pyo

# ── Editor / IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS generated ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────
logs/
*.log

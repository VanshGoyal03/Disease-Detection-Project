# ╔══════════════════════════════════════════════════════════════════════╗
# ║               KISAAN BANDHU — Environment Variables                 ║
# ║  Copy this file to .env and fill in your real values.              ║
# ║  NEVER commit .env to GitHub — it is in .gitignore.               ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── 🌱 CROP DISEASE API (Primary identifier — Server.js STEP 1) ────────
# Used to identify the disease name + confidence from the crop image.
# ⚠️  CHANGE THIS: Get your key from https://crop.kindwise.com
#     Sign up → Dashboard → API Keys → Create Key
#     (Free tier: 100 identifications/month)
CROP_HEALTH_API_KEY=your_crop_health_api_key_here

# ── 🤖 GEMINI AI KEY (Backend — Server.js STEP 2) ──────────────────────
# Used AFTER crop API: Gemini generates severity, cure, precautions etc.
# Also used as FALLBACK if CROP_HEALTH_API_KEY is not set (Gemini Vision).
# ⚠️  CHANGE THIS: Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── 🤖 GEMINI AI KEYS (Frontend — Vite browser bundle) ────────────────
# These run in the user's browser (chatbot + inline disease chat).
# ⚠️  CHANGE THIS: Same source — https://aistudio.google.com/apikey
#     Can be the same key as GEMINI_API_KEY above.
VITE_GEMINI_CHAT_KEY=your_gemini_api_key_here
VITE_GEMINI_DETECT_KEY=your_gemini_api_key_here

# ── 🗄️  SUPABASE (Backend — authentication & database) ─────────────────
# ⚠️  CHANGE THIS: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── ⚙️  SERVER SETTINGS ────────────────────────────────────────────────
# Port the Node.js backend (Server.js) listens on.
PORT=3001

# ── 🌐 FRONTEND → BACKEND URL ─────────────────────────────────────────
# ⚠️  CHANGE THIS for production: set to your deployed backend domain
VITE_API_URL=http://localhost:3001
